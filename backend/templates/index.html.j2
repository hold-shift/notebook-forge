<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
{# Discoverability layer — generated, never hand-maintained. #}
{% if og_description %}<meta name="description" content="{{ og_description }}">{% endif %}
{% if canonical_url %}<link rel="canonical" href="{{ canonical_url }}">{% endif %}
<meta property="og:type" content="website">
<meta property="og:title" content="{{ title }}">
{% if og_description %}<meta property="og:description" content="{{ og_description }}">{% endif %}
{% if canonical_url %}<meta property="og:url" content="{{ canonical_url }}">{% endif %}
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="{{ title }}">
{% if og_description %}<meta name="twitter:description" content="{{ og_description }}">{% endif %}
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --khaki:       #6b6b3a;
    --khaki-light: #e8e7d8;
    --khaki-mid:   #b5b48a;
    --khaki-dark:  #4a4a26;
    --ink:         #111110;
    --ink-secondary: #444440;
    --ink-tertiary:  #888880;
    --rule:        #e0dfd8;
    --bg:          #ffffff;
    --bg-offset:   #f8f8f5;
  }

  body { background: var(--bg); font-family: Georgia, 'Times New Roman', serif; color: var(--ink); }
  .page { max-width: 720px; margin: 0 auto; padding: 3.5rem 2rem; }

  .eyebrow { font-family: system-ui, sans-serif; font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--ink-tertiary); margin-bottom: .65rem; }
  .masthead { border-bottom: 2px solid var(--khaki); padding-bottom: 1.75rem; margin-bottom: 2rem; }
  .masthead h1 { font-size: 42px; font-weight: 400; line-height: 1.1; color: var(--ink); margin-bottom: .4rem; }
  .masthead .dates { font-family: system-ui, sans-serif; font-size: 14px; letter-spacing: .06em; color: var(--khaki); text-transform: uppercase; margin-bottom: 1rem; }
  .masthead .tagline { font-size: 17px; color: var(--ink-secondary); line-height: 1.75; max-width: 520px; }
  .dedication { font-style: italic; font-size: 15px; color: var(--ink-tertiary); margin-top: 1.25rem; }

  .banner { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; border: 1px solid var(--rule); border-radius: 6px; overflow: hidden; margin-bottom: 2rem; }
  .banner-cell { background: var(--bg-offset); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; padding: 2rem .75rem 1.25rem; border-right: 1px solid var(--rule); position: relative; }
  .banner-cell:last-child { border-right: none; }
  .banner-cell svg { opacity: .25; }
  .banner-cell img { max-width: 100%; height: auto; border-radius: 3px; }
  .banner-cell .img-label { font-family: system-ui, sans-serif; font-size: 10px; color: var(--ink-tertiary); text-align: center; line-height: 1.4; }
  .banner-cell .era { font-family: system-ui, sans-serif; font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--khaki); position: absolute; top: .75rem; left: 50%; transform: translateX(-50%); white-space: nowrap; }
  .banner-cell .adapted { font-family: system-ui, sans-serif; font-size: 9px; color: #bbb; margin-top: 2px; text-align: center; }

  .cta { display: flex; align-items: center; gap: 14px; padding: 1rem 1.25rem; border: 1px solid var(--rule); border-left: 3px solid var(--khaki); border-radius: 0 6px 6px 0; background: var(--bg-offset); margin-bottom: 2.5rem; text-decoration: none; color: inherit; }
  .cta-title { font-family: system-ui, sans-serif; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 2px; }
  .cta-sub { font-family: system-ui, sans-serif; font-size: 12px; color: var(--ink-tertiary); }
  .cta-arrow { font-size: 18px; color: var(--khaki-mid); margin-left: auto; flex-shrink: 0; }

  .section-label { font-family: system-ui, sans-serif; font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-tertiary); margin-bottom: 1.25rem; }
  .timeline { position: relative; padding-left: 1.75rem; }
  .timeline::before { content: ''; position: absolute; left: 3px; top: 6px; bottom: 6px; width: 1px; background: var(--rule); }

  .tgroup { margin-bottom: 1.5rem; }
  .tgroup-header { display: flex; align-items: center; gap: 10px; margin-bottom: .65rem; position: relative; }
  /* Centre the dot on the 1px rule (at left:3px) and vertically on its row. */
  .tdot { width: 8px; height: 8px; border-radius: 50%; background: var(--khaki); flex-shrink: 0; position: absolute; left: calc(-1.75rem - 0.5px); top: 50%; transform: translateY(-50%); }
  .tgroup-name { font-family: system-ui, sans-serif; font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--khaki); }

  .memoir-item { display: flex; align-items: center; gap: 10px; padding: .65rem .9rem; background: var(--bg); border: 1px solid var(--rule); border-radius: 5px; text-decoration: none; color: inherit; margin-bottom: 4px; }
  .memoir-item:hover { border-color: var(--khaki-mid); }
  .memoir-period { font-family: system-ui, sans-serif; font-size: 11px; color: var(--ink-tertiary); min-width: 72px; flex-shrink: 0; }
  .memoir-title { font-size: 15px; color: var(--ink); flex: 1; }
  .memoir-meta { font-family: system-ui, sans-serif; font-size: 11px; color: var(--ink-tertiary); flex-shrink: 0; margin-right: 6px; }
  .memoir-arrow { color: var(--khaki-mid); font-size: 14px; }

  .closing { margin-top: 3.5rem; padding-top: 2rem; border-top: 1px solid var(--rule); }
  .closing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 1.5rem; }
  .closing p { font-size: 15px; line-height: 1.85; color: var(--ink-secondary); margin-bottom: 1rem; }
  .closing p:last-of-type { margin-bottom: 0; }
  .closing-col h3 { font-family: system-ui, sans-serif; font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--khaki); margin-bottom: .85rem; }
  .notebooklm-features { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .notebooklm-features li { font-family: system-ui, sans-serif; font-size: 13px; color: var(--ink-secondary); display: flex; align-items: baseline; gap: 8px; line-height: 1.5; }
  .notebooklm-features li::before { content: '—'; color: var(--khaki-mid); flex-shrink: 0; }
  .signoff { font-style: italic; font-size: 15px; color: var(--ink-tertiary); margin-top: 1.5rem; }

  footer { font-family: system-ui, sans-serif; font-size: 11px; color: var(--ink-tertiary); margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--rule); line-height: 1.7; }

  @media (max-width: 600px) {
    .closing-grid { grid-template-columns: 1fr; }
  }
</style>
{{ jsonld_script|safe }}
</head>
<body>
<div class="page">

  {# Each banner slot keeps its own placeholder SVG (copied verbatim from the
     mockup), shown only when no image has been uploaded for that slot. #}
  {%- macro placeholder_svg(i) -%}
    {%- if i == 0 -%}
      <svg width="48" height="60" viewBox="0 0 24 30" fill="none" stroke="#6b6b3a" stroke-width="1.2">
        <circle cx="12" cy="8" r="5"/>
        <path d="M4 28c0-5 3.6-8 8-8s8 3 8 8"/>
        <rect x="8" y="13" width="8" height="3" rx="1"/>
      </svg>
    {%- elif i == 1 -%}
      <svg width="56" height="44" viewBox="0 0 28 22" fill="none" stroke="#6b6b3a" stroke-width="1.2">
        <rect x="2" y="6" width="24" height="14" rx="2"/>
        <rect x="6" y="9" width="4" height="4" rx="1"/>
        <rect x="18" y="9" width="4" height="3" rx="1"/>
        <path d="M2 10h24"/>
        <circle cx="7" cy="20" r="2"/>
        <circle cx="21" cy="20" r="2"/>
        <path d="M12 2c0 0 2-2 5-2s7 2 8 6"/>
      </svg>
    {%- else -%}
      <svg width="44" height="56" viewBox="0 0 22 28" fill="none" stroke="#6b6b3a" stroke-width="1.2">
        <circle cx="11" cy="4" r="2.5"/>
        <line x1="11" y1="6.5" x2="11" y2="28"/>
        <line x1="11" y1="10" x2="4" y2="22"/>
        <line x1="11" y1="10" x2="18" y2="22"/>
        <circle cx="11" cy="7" r="3.5" stroke-dasharray="2 1"/>
        <line x1="7" y1="15" x2="15" y2="15"/>
      </svg>
    {%- endif -%}
  {%- endmacro -%}

  <div class="masthead">
    <p class="eyebrow">The Skitch Family Archive</p>
    <h1>{{ content.subject_name }}</h1>
    <p class="dates">b. {{ content.subject_birth }} &nbsp;·&nbsp; {{ content.subject_place }}</p>
    {% if content.tagline %}<p class="tagline">{{ content.tagline }}</p>{% endif %}
    {% if dedication %}<p class="dedication">{{ dedication }}</p>{% endif %}
  </div>

  <div class="banner">
    {% for slot in content.banner_slots %}
    <div class="banner-cell">
      {% if slot.era %}<span class="era">{{ slot.era }}</span>{% endif %}
      {% if slot.image_url %}
      <img src="{{ slot.image_url }}" alt="{{ slot.caption }}">
      {% else %}
      {{ placeholder_svg(loop.index0) }}
      {% endif %}
      {% if slot.caption %}<p class="img-label">{{ slot.caption }}</p>{% endif %}
      {% if slot.notebooklm_adapted %}<p class="adapted">[NotebookLM edition — image adapted]</p>{% endif %}
    </div>
    {% endfor %}
  </div>

  <a class="cta" href="{{ content.notebooklm_url }}" target="_blank" rel="noopener">
    <div>
      <p class="cta-title">{{ content.notebooklm_cta_title }}</p>
      {% if content.notebooklm_cta_subtitle %}<p class="cta-sub">{{ content.notebooklm_cta_subtitle }}</p>{% endif %}
    </div>
    <span class="cta-arrow">→</span>
  </a>

  <p class="section-label">Memoirs</p>

  <div class="timeline">
    {% for group in timeline %}
    <div class="tgroup">
      <div class="tgroup-header">
        <div class="tdot"></div>
        <span class="tgroup-name">{{ group.name }}</span>
      </div>
      {% for row in group.rows %}
      <a class="memoir-item" href="{{ row.url }}">
        <span class="memoir-period">{{ row.period }}</span><span class="memoir-title">{{ row.title }}</span>{% if row.reading_time %}<span class="memoir-meta">{{ row.reading_time }}</span>{% endif %}<span class="memoir-arrow">→</span>
      </a>
      {% endfor %}
    </div>
    {% endfor %}
  </div>

  <div class="closing">
    <p class="section-label">About this archive</p>
    <div class="closing-grid">
      <div class="closing-col">
        <h3>The archive</h3>
        {% for para in content.about_archive_paras %}<p>{{ para }}</p>{% endfor %}
        {% if content.signoff %}<p class="signoff">{{ content.signoff }}</p>{% endif %}
      </div>
      <div class="closing-col">
        <h3>Exploring with NotebookLM</h3>
        {% for para in content.about_notebooklm_paras %}<p>{{ para }}</p>{% endfor %}
        {% if content.notebooklm_features %}
        <ul class="notebooklm-features">
          {% for feature in content.notebooklm_features %}<li>{{ feature }}</li>{% endfor %}
        </ul>
        {% endif %}
        <p style="margin-top:1rem"><a href="{{ content.notebooklm_url }}" style="color:var(--khaki);font-family:system-ui,sans-serif;font-size:13px">Open the collection in NotebookLM →</a></p>
      </div>
    </div>
  </div>

  {% if footer_text %}
  <footer>{{ footer_text|safe }}</footer>
  {% endif %}

</div>
</body>
</html>
