# Secrets — never commit
.env
.env.*
secret/

# Read-only external reference material (cloned, not ours to version)
vendor-readonly/

# Python
__pycache__/
*.pyc
.venv/
.ruff_cache/
.pytest_cache/
*.egg-info/

# Node
node_modules/
frontend/dist/

# Workspace / runtime artefacts (live outside the repo by default, but guard anyway)
*.db
*.db-wal
*.db-shm

# OS
.DS_Store

# Internal planning docs & operator notes (kept local, not published)
docs/

# Generated validation/coverage output (recreated by tests & CLI)
reports/

# Internal planning notes (kept local, not published)
/SPRINT_REPORT.md
/BUILD_PLAN.md
